{
  "name": "LinkedIn Career Advice",
  "description": "Actionable career guidance and professional development advice for LinkedIn",
  "platform": "LinkedIn",
  "estimated_length": "3-5 minutes",
  "structure": [
    {
      "section": "Career Challenge Hook",
      "duration": "0:00-0:30",
      "description": "Identify a common career challenge or question",
      "hook_formats": [
        "Have you ever struggled with [career challenge]?",
        "The most common mistake I see professionals make...",
        "If you want to advance in [field], avoid this...",
        "A simple framework that helped me [career achievement]"
      ],
      "relatability": "Immediately connect with common professional pain points"
    },
    {
      "section": "Personal Experience / Credibility",
      "duration": "0:30-1:00",
      "description": "Share relevant personal or client experience",
      "story_types": [
        "How I overcame this challenge",
        "Client case study transformation",
        "Common pattern observed across professionals",
        "Data/statistics supporting the advice"
      ],
      "authenticity": "Real experience, not just theory"
    },
    {
      "section": "Framework / Methodology",
      "duration": "1:00-2:30",
      "description": "Present a clear, actionable framework",
      "framework_characteristics": [
        "Simple to understand (3-5 steps max)",
        "Memorable acronym or structure",
        "Visual diagram or flowchart",
        "Step-by-step implementation guide"
      ],
      "visual_aids": [
        "[SHOW: Framework diagram]",
        "[DISPLAY: Step-by-step checklist]",
        "[HIGHLIGHT: Key principles]",
        "[COMPARE: Before/after approach]"
      ]
    },
    {
      "section": "Implementation Examples",
      "duration": "2:30-3:30",
      "description": "Show how to apply the framework in real situations",
      "example_types": [
        "Different career levels (entry, mid, senior)",
        "Various industries or roles",
        "Common scenarios (interview, promotion, skill development)",
        "Before/after transformation stories"
      ],
      "practicality": "Viewers can see exactly how to use it"
    },
    {
      "section": "Common Pitfalls & Solutions",
      "duration": "3:30-4:00",
      "description": "Anticipate and address implementation challenges",
      "pitfall_categories": [
        "Time management issues",
        "Skill gaps to address",
        "Mindset obstacles",
        "Resource constraints"
      ],
      "solutions": "Practical workarounds and alternatives"
    },
    {
      "section": "Success Metrics & Timeline",
      "duration": "4:00-4:30",
      "description": "Define what success looks like and when to expect results",
      "metrics": [
        "Quantifiable outcomes (promotions, salary increases, skill mastery)",
        "Qualitative improvements (confidence, satisfaction, recognition)",
        "Timeline expectations (30/60/90 day milestones)",
        "Adjustment criteria (when to pivot approach)"
      ],
      "realistic_expectations": "Manage expectations while maintaining motivation"
    },
    {
      "section": "Community Discussion & Resources",
      "duration": "4:30-5:00",
      "description": "Encourage professional dialogue and provide additional help",
      "engagement_methods": [
        "Ask for specific experiences in comments",
        "Pose reflection questions",
        "Share additional resources (templates, tools, articles)",
        "Offer to answer specific questions"
      ],
      "value_add": "Extend value beyond the video itself"
    }
  ],
